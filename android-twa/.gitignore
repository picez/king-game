# Android TWA scaffold — commit ONLY the Bubblewrap config + README.
# Everything below is generated by `bubblewrap init/build` or is a signing
# secret and must NEVER be committed.

# --- Signing keys / secrets (NEVER commit) ---
*.keystore
*.jks
*.p12
*.pepk
android.keystore
upload-key*.pem
keystore.properties
signing.properties

# --- Build outputs / release bundles (NEVER commit) ---
*.apk
*.aab
*.idsig
build/
app/build/
release/

# --- Bubblewrap / Gradle generated project (regenerated by `bubblewrap build`) ---
# The whole native Android project is generated from twa-manifest.json; do not
# commit it. Regenerate any time with `bubblewrap build` (or `bubblewrap update`).
.gradle/
gradle/
gradlew
gradlew.bat
app/
build.gradle
settings.gradle
gradle.properties
local.properties
twa-manifest.json.bak
store_icon.png
*.log
