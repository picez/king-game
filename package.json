{
  "name": "king-card-game",
  "private": true,
  "version": "0.4.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/strip-preview.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "verify": "npm run typecheck:server && npm test && npm run build && npm run e2e",
    "icons": "node scripts/generate-icons.mjs",
    "visuals": "node scripts/gen-visual-assets.mjs",
    "visuals:webp": "node scripts/optimize-webp.mjs",
    "sounds": "node scripts/gen-sound-assets.mjs",
    "cards": "node scripts/slice-card-sources.mjs",
    "e2e": "tsx scripts/e2e-online.mjs",
    "social-shots": "node scripts/social-shots.mjs",
    "soak": "tsx scripts/durak-soak.mjs",
    "soak:deberc": "tsx scripts/deberc-soak.mjs",
    "start": "NODE_ENV=production tsx server/index.ts",
    "server": "tsx server/index.ts",
    "server:prod": "NODE_ENV=production tsx server/index.ts",
    "rooms:cleanup": "tsx server/cleanup.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^4.1.9"
  }
}
