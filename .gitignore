node_modules/
dist/

# Server-side room persistence (file storage default location)
.data/
# E2E / smoke temp data dirs (auto-created, auto-removed)
.data-*/
# Atomic-write temp files
*.tmp

# Editor / OS noise
.DS_Store
*.log

# Mobile QA screenshots (local only)
.shots/

# Local Claude Code / agent permissions (machine-specific)
.claude/

# Large source sprite-sheets for card art (kept locally; sliced into
# public/cards/faces/ which IS committed). Not needed at runtime.
card-sources/

# Android TWA scaffold — never commit signing keys or build outputs, even if
# the native Android project is generated inside android-twa/ (see its README).
android-twa/**/*.keystore
android-twa/**/*.jks
android-twa/**/*.apk
android-twa/**/*.aab
android-twa/**/build/
android-twa/**/.gradle/
