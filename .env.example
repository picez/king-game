# King — production environment example
# ---------------------------------------------------------------------------
# Copy to `.env` and edit. Two ways to use it on the VPS:
#   • systemd:  ExecStart reads it via `EnvironmentFile=/srv/king/.env`
#   • shell:    `set -a; . ./.env; set +a; npm run server:prod`
#
# NOTE: the Node server reads process.env directly (no dotenv autoload), so the
# file only takes effect through systemd EnvironmentFile or an explicit export.
# Use plain KEY=value lines (no `export`, no quotes) for systemd compatibility.
# ---------------------------------------------------------------------------

# Bind to localhost — the reverse proxy (Caddy/nginx) terminates TLS and
# forwards to this address on the same box.
HOST=127.0.0.1
PORT=3001

# Enables stricter startup warnings (e.g. warns if ALLOWED_ORIGINS is unset).
NODE_ENV=production

# Only your site's origin may open a WebSocket. Comma-separated for several.
# Replace <domain> with your real host, e.g. https://king.example.com
ALLOWED_ORIGINS=https://<domain>

# Room persistence file. Put it on a persistent path; chmod 600 (sensitive:
# holds full hands + reconnect tokens). Set ROOM_STORAGE=memory to disable.
ROOM_STORAGE_FILE=.data/rooms.json

# Idle rooms with no connected players are deleted after this many hours;
# rooms with a connected player survive until the hard cap.
ROOM_TTL_HOURS=24
ROOM_HARD_TTL_HOURS=48

# ---------------------------------------------------------------------------
# CLIENT (build-time only — NOT read by the server). The client bakes this in
# at `npm run build`. Required for the path-based proxy below: without it an
# HTTPS page defaults to wss://<host> (root), which the proxy routes to static
# files, not the WS server. Set it to the proxied /ws path and rebuild:
#
#   VITE_WS_URL=wss://<domain>/ws npm run build
# ---------------------------------------------------------------------------
# VITE_WS_URL=wss://<domain>/ws

# ---------------------------------------------------------------------------
# RENDER (single Web Service) — see RENDER_DEPLOY.md / render.yaml.
# On Render set HOST=0.0.0.0 and DO NOT set PORT (Render injects it). Because
# the client is served from the same origin, it auto-connects to
# wss://<your-service>.onrender.com/ws — so VITE_WS_URL is OPTIONAL there.
# Example dashboard values:
#   NODE_ENV=production
#   HOST=0.0.0.0
#   ALLOWED_ORIGINS=https://<your-service>.onrender.com
#   ROOM_TTL_HOURS=24
#   ROOM_HARD_TTL_HOURS=48
# ---------------------------------------------------------------------------
